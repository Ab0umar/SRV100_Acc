        SQLText.Strings = (
          'SELECT 1grp,drs_cd,CA_CD,PAT_CD,'
          
            '( SELECT PAT_NM_AR FROM PAPATMF WHERE PAT_CD=PAPAT_IO.PAT_CD ) A' +
            'S PAT_NM, '
          
            '( SELECT CA_NM_AR FROM CMPMF WHERE CA_CD = PAPAT_IO.CA_CD ) AS C' +
            'A_NM,'
          
            '( SELECT PHNM_AR FROM MDTEAM WHERE CODE = PAPAT_IO.drs_cd ) AS D' +
            'OC_NM,'
          
            'SUM(CASE WHEN ca_cd = '#39'00000'#39'and pat_typ=1 THEN 1 ELSE 0 END) as' +
            ' ahaly_INTO,'
          
            'SUM(CASE WHEN ca_cd <> '#39'00000'#39'and pat_typ=1 THEN 1 ELSE 0 END) a' +
            's t3a2od_INTO'
          'FROM PAPAT_IO '
          'WHERE DRS_CD <> '#39#39
          'AND PAT_TYP=1'
