      object daSQL1: TdaSQL
        GuidCollationType = gcMSAccess
        DatabaseName = 'DAT'
        DatabaseType = dtMSAccess
        DataPipelineName = 'x'
        EditSQLAsText = True
        LinkColor = clMaroon
        LinkType = ltParameterizedSQL
        MaxSQLFieldAliasLength = 0
        SQLText.Strings = (
          ' SELECT distinct S.*,'
          '(select srv_nm_Ar from srvcmf where srv_cd= S.SRV_CD)AS SRV_NM ,'
          '(s.qty*s.prc)as tot,'
          '( select phnm_ar from mdteam where code=s.srv_by1)as phnm_ar,'
          '( select CA_NM_AR from CMPMF where CA_CD=s.CA_CD)as CA_NM'
          'FROM (PAPAT_SRV S LEFT JOIN PAPAT_IO PAPAT_IO '
          
            'ON (S.PAT_CD=PAPAT_IO.PAT_CD) AND (S.VST_NO=PAPAT_IO.VST_NO)) LE' +
            'FT JOIN PAPATMF PAPATMF '
          'ON S.PAT_CD=PAPATMF.PAT_CD Where 1=1 Order by S.PAT_CD')
        SQLType = sqSQL2
