{
  "name": "SELRS",
  "version": "1.0.151",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "cross-env NODE_ENV=development tsx watch server/_core/index.ts",
    "check:encoding": "node scripts/check-mojibake.mjs",
    "build": "pnpm check:encoding && vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:watch": "cross-env FAST_BUILD=1 vite build && esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "build:server:watch": "esbuild server/_core/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "cross-env NODE_ENV=production node dist/index.js",
    "dev:prod-watch": "node scripts/watch-build-start.mjs",
    "check": "tsc --noEmit",
    "format": "prettier --write .",
    "test": "vitest run",
    "test:ui": "playwright test",
    "db:migrate": "tsx scripts/db-migrate.ts",
    "db:sync-check": "tsx scripts/check-db-sync.ts",
    "db:migration-files-check": "tsx scripts/check-migration-files.ts",
    "db:ensure-admin-active": "tsx scripts/ensure-active-admin.ts",
    "db:sync-user-permissions-to-role": "tsx scripts/sync-user-permissions-to-role.ts",
    "db:push": "drizzle-kit generate && drizzle-kit migrate",
    "db:backup": "powershell -ExecutionPolicy Bypass -File scripts/backup-db.ps1",
    "db:restore": "powershell -ExecutionPolicy Bypass -File scripts/restore-db.ps1",
    "s3:preview-dedup": "tsx scripts/preview-dedup-blackice.ts",
    "s3:dedup-blackice": "tsx scripts/deduplicate-blackice.ts",
    "s3:dedup-batch": "tsx scripts/deduplicate-blackice-batch.ts",
    "s3:dedup-simple": "tsx scripts/deduplicate-simple.ts",
    "s3:migrate-blackice": "tsx scripts/migrate-blackice-to-s3.ts",
    "create-user": "tsx scripts/createUser.ts",
    "templates:export-ready-prescriptions": "tsx scripts/export-ready-prescriptions-to-excel.ts",
    "templates:convert-multisheet": "node scripts/convert-ready-prescriptions-to-multisheet.mjs",
    "smoke": "tsx scripts/smoke.ts",
    "hooks:install": "git config core.hooksPath .githooks",
    "android:build-release": "powershell -ExecutionPolicy Bypass -File scripts/build-android-release.ps1",
    "web:deploy": "powershell -ExecutionPolicy Bypass -File scripts/deploy-web.ps1"
  },
