                                <thead>
                                  <tr className="bg-gradient-to-r from-cyan-600 to-cyan-700 text-white">
                                    <th className="px-1 py-1 text-center font-bold whitespace-nowrap text-[11px]">العين</th>
                                    <th className="px-1 py-1 text-center font-bold whitespace-nowrap text-[11px]">UCVA</th>
                                    <th className="px-1 py-1 text-center font-bold whitespace-nowrap text-[11px]">S</th>
                                    <th className="px-1 py-1 text-center font-bold whitespace-nowrap text-[11px]">C</th>
                                    <th className="px-1 py-1 text-center font-bold whitespace-nowrap text-[11px]">AXIS</th>
                                    <th className="px-1 py-1 text-center font-bold whitespace-nowrap text-[11px]">IOP</th>
                                  </tr>
